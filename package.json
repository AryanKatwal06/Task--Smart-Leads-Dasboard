{
  "name": "smart-leads-dashboard",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev": "node scripts/dev.cjs",
    "dev:client": "npm --workspace=client run dev",
    "dev:server": "npm --workspace=server run dev",
    "start:scheduler": "npm --workspace=server run start:scheduler",
    "lint": "eslint --ext .ts,.tsx --report-unused-disable-directives . || true",
    "lint:ci": "eslint --ext .ts,.tsx --max-warnings 0 .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "prettier": "^3.0.0"
  }
}
